# ─── Server ───────────────────────────────────────────────
PORT=3000
APP_HOST_PORT=3000
NODE_ENV=development

# ─── Database (Docker Compose) ────────────────────────────
MYSQLHOST=db
MYSQLPORT=3306
MYSQLHOST_PORT=3307
MYSQL_DATABASE=web_db
MYSQLUSER=root
MYSQL_ROOT_PASSWORD=example

# ─── URL ──────────────────────────────────────────────────
BASE_URL=https://your_domain.com/
DOMAIN=your_domain

# ─── Google Auth (OAuth login) ────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Google Cloud TTS (voir app/config/README-TTS-CREDENTIALS.md) ──
# Extraire project_id, client_email, private_key du fichier JSON du service account
# Pour private_key : remplacer chaque retour à la ligne par \n (deux caractères)
GOOGLE_TTS_PROJECT_ID=
GOOGLE_TTS_CLIENT_EMAIL=
GOOGLE_TTS_PRIVATE_KEY=

# ─── Gemini ───────────────────────────────────────────────
GEMINI_API_KEY=

# ─── AWS SES ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1
AWS_SES_FROM=

# ─── Email ────────────────────────────────────────────────
USER_GMAIL=
