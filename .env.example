# ─── Server ───────────────────────────────────────────────
PORT=3000
HOST_PORT=3000
NODE_ENV=development

# ─── Database (Docker Compose) ────────────────────────────
MYSQLHOST=db
MYSQLPORT=3306
MYSQLHOST_PORT=3307
MYSQL_DATABASE=web_db
MYSQLUSER=root
MYSQL_ROOT_PASSWORD=example

# ─── Redis (Docker Compose / Railway) ──────────────────────
REDISHOST=redis
REDISPORT=6379
# Docker local : pas de mot de passe (laisser vide). Railway : injecté via REDIS_URL automatiquement.
REDIS_PASSWORD=
# Optionnel : si défini, REDIS_URL a la priorité sur host/port/password ci-dessus
# REDIS_URL=

# ─── Session ───────────────────────────────────────────────
# OBLIGATOIRE partout. Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Railway : ajouter comme variable d'environnement dans le service.
SESSION_SECRET=

# ─── Cron Jobs / Automated Tasks ─────────────────────────────
# Secret pour protéger l'endpoint POST /api/reminder (envoi d'emails de masse).
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Le cron job doit envoyer ce secret dans le header X-Cron-Secret.
CRON_SECRET=

# ─── URL ──────────────────────────────────────────────────
BASE_URL=https://your_domain.com/
DOMAIN=your_domain

# ─── Google Auth (OAuth login) ────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Google Cloud TTS (voir app/config/README-TTS-CREDENTIALS.md) ──
# Extraire project_id, client_email, private_key du fichier JSON du service account
# Pour private_key : remplacer chaque retour à la ligne par \n (deux caractères)
GOOGLE_TTS_PROJECT_ID=
GOOGLE_TTS_CLIENT_EMAIL=
GOOGLE_TTS_PRIVATE_KEY=
GOOGLE_TTS_PRIVATE_KEY_ID=
GOOGLE_TTS_CLIENT_ID=
GOOGLE_TTS_CLIENT_X509_CERT_URL=

# ─── Gemini ───────────────────────────────────────────────
GEMINI_API_KEY=

# ─── AWS SES ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_SES_FROM=

# ─── Email ────────────────────────────────────────────────
USER_GMAIL=

# ─── RabbitMQ (Docker Compose / Railway) ─────────────────────
RABBITMQ_DEFAULT_HOST=rabbitmq
RABBITMQ_DEFAULT_PORT=5672
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest


# ─── Staging interceptor (only used in staging environment)
STAGING_EMAIL_INTERCEPT=
