{
  "main": "app.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon --inspect app.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "migrate": "node scripts/run-migrations.js",
    "migrate:safe": "node scripts/backup-db.js && node scripts/run-migrations.js",
    "backup:db": "node scripts/backup-db.js",
    "restore:db": "node scripts/restore-db.js",
    "prepare": "node -e \"require('fs').existsSync('.git')&&require('child_process').execSync('npx husky',{stdio:'inherit'})\""
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/client-sesv2": "^3.0.0",
    "@google-cloud/text-to-speech": "^6.2.0",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.12.0",
    "bcryptjs": "^3.0.2",
    "connect-redis": "^9.0.0",
    "dompurify": "^3.2.6",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-handlebars": "^8.0.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "html-entities": "^2.6.0",
    "jsdom": "^26.1.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.1",
    "mysql2": "^3.14.0",
    "nodemailer": "^8.0.1",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.11.0",
    "validator": "^13.15.15",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.7",
    "nodemon": "^3.1.9",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2"
  }
}
